# 环境变量示例文件
# 复制此文件为 .env 并填入实际值

# 应用配置
# VITE_APP_TITLE=书籍Best10生成器

# API配置（当前使用公开代理，无需配置）
# VITE_DOUBAN_API_URL=https://douban.uieee.com/v2/book

# 功能开关
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG=false

# 注意：
# 1. 所有环境变量必须以 VITE_ 开头才能在客户端访问
# 2. 不要在此文件中存储敏感信息
# 3. .env 文件已在 .gitignore 中，不会被提交到版本控制
